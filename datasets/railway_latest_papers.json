mmary":{"word_count":4513,"sections_present":2,"sections_missing":["introduction","methodology","results","discussion","conclusion"],"red_flags":[],"red_flag_count":0,"has_formal_proofs":true,"has_equations":false,"has_code":true,"unique_refs":14,"has_placeholder_refs":false,"depth_score":1,"evidence_markers":9,"deception_count":0,"deception_matches":[],"grammar":{"vocabulary_diversity":0.376,"is_monotone":false,"is_low_vocabulary":false},"repetition_ratio":0.016,"code_quality":{"blocks":4,"has_real_code":false,"has_python":true},"math_formulas":10,"lean4":"code_present","tables":3},"adjustments":{"abstract":["red_flag_penalty: -1 (code_blocks_are_template_not_real)","llm_inflation_correction: 7.3 -> 6.5","outlier_6.5_vs_mean_2.9: capped at 5.9"],"introduction":["red_flag_penalty: -1 (code_blocks_are_template_not_real)","section_missing: 6.7 Г”ГҘГҶ 0"],"methodology":["red_flag_penalty: -1 (code_blocks_are_template_not_real)","section_missing: 6.3 Г”ГҘГҶ 0"],"results":["red_flag_penalty: -1 (code_blocks_are_template_not_real)","section_missing: 6 Г”ГҘГҶ 0"],"discussion":["red_flag_penalty: -1 (code_blocks_are_template_not_real)","section_missing: 5.6 Г”ГҘГҶ 0"],"conclusion":["red_flag_penalty: -1 (code_blocks_are_template_not_real)","section_missing: 5.3 Г”ГҘГҶ 0"],"references":["red_flag_penalty: -1 (code_blocks_are_template_not_real)","llm_inflation_correction: 5 -> 4.6"],"novelty":["red_flag_penalty: -1 (code_blocks_are_template_not_real)","llm_inflation_correction: 5.6 -> 5.1"],"reproducibility":["red_flag_penalty: -1 (code_blocks_are_template_not_real)","lean4_code_present: +2 formal verification bonus","llm_inflation_correction: 9 -> 7.9","outlier_7.9_vs_mean_2.9: capped at 5.9"],"citation_quality":["red_flag_penalty: -1 (code_blocks_are_template_not_real)","llm_inflation_correction: 4.9 -> 4.5"]},"adjustment_count":10,"reference_papers":["New Directions in Cryptography"],"false_positive_corrected":"code_blocks_are_template_not_real (live verification confirmed