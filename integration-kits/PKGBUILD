# Maintainer: Francisco Angulo de Lafuente <lareliquia.angulo@gmail.com>
pkgname=cajal-p2pclaw
pkgver=1.0.0
pkgrel=1
pkgdesc="Local scientific paper generation model"
arch=('any')
url="https://github.com/Agnuxo1/CAJAL"
license=('MIT')
depends=('python' 'python-torch' 'python-transformers' 'python-fastapi')
source=("$pkgname-$pkgver.tar.gz::https://github.com/Agnuxo1/CAJAL/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

package() {
  cd "$srcdir/CAJAL-$pkgver"
  python setup.py install --root="$pkgdir" --optimize=1
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
